# Copy to .env (gitignored) and fill in what you use. Docker Compose auto-loads
# .env for ${VAR} interpolation, and scripts/run_api.sh sources it too, so the
# venv and Docker paths read the same config.

# Compute backend for the heavy stage: local (CPU, default) | modal | runpod
LYRICSYNC_BACKEND=local

# --- Modal (LYRICSYNC_BACKEND=modal) ---
# Deployed app name.
LYRICSYNC_MODAL_APP=lyricsync
# Modal token. Get the values with `modal token new` (or copy token_id /
# token_secret out of ~/.modal.toml).
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# --- RunPod (LYRICSYNC_BACKEND=runpod) ---
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=

# Seconds a warm GPU container lingers after a job before scaling to zero.
# Modal reads this at deploy time (re-run scripts/deploy_modal.sh to change it).
# RunPod ignores it -- set the equivalent "Idle Timeout" on the endpoint in the
# RunPod console (the worker image can't set platform scaling).
#LYRICSYNC_GPU_IDLE_SECS=300

# --- stable-ts align() tuning (optional; applies on whichever backend) ---
# Speed up alignment; best when lyrics are accurate and gaps are short.
#LYRICSYNC_FAST_MODE=1
# Skip non-speech sections >= N seconds (default 5; "none" disables skipping).
#LYRICSYNC_NONSPEECH_SKIP=5
# Silero VAD to suppress timestamps on non-speech (default on for music; 0 disables).
#LYRICSYNC_VAD=1

# CORS origins for the API (default *)
#LYRICSYNC_CORS=*
